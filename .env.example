# Copy to ".env" and fill in. Never commit your real .env.

# --- Telegram (trigger + confirmation reply) ---
# Create a bot with @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# --- Todoist (destination) ---
# Settings -> Integrations -> Developer -> API token
TODOIST_API_TOKEN=your-todoist-api-token

# --- Local services (defaults match docker-compose service names) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
WHISPER_URL=http://faster-whisper:8000
WHISPER_MODEL=Systran/faster-whisper-base.en
